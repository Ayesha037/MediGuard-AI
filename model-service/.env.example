# Copy to .env for local development. In production, set these as real
# secrets in your platform's dashboard (Render/Railway/Fly/AWS Secrets
# Manager/etc.) — never commit a real .env file.

SERVICE_NAME=MediGuard AI Prediction Service
ENVIRONMENT=production

# Comma-separated list of valid API keys. Rotate by adding a new key,
# updating callers, then removing the old one — no downtime.
API_KEYS=changeme-generate-a-real-key

# Comma-separated list of allowed origins, or "*" for any (fine for a
# server-to-server API with no browser callers; tighten if a browser
# frontend calls this directly).
CORS_ORIGINS=*

RATE_LIMIT_PER_MINUTE=120

FAILURE_PROB_HIGH_THRESHOLD=0.70
FAILURE_PROB_MEDIUM_THRESHOLD=0.35

LOG_LEVEL=INFO
